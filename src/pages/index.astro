---
import BookingForm from "../components/BookingForm.astro";
import Layout from "../layouts/Layout.astro";

const serviceGallery = [
  {
    image: "/BarberShop/41d0c124032b10f4038d258d175b5e2e.jpg",
    alt: "Perfilado de barba en barberia"
  },
  {
    image: "/BarberShop/7f17e1cc5b84a0ba8e025edcfead36e4.jpg",
    alt: "Corte moderno con fade",
    featured: true
  },
  {
    image: "/BarberShop/Master the Art of Barbering with PB Academy’s Barber Course!.jpeg",
    alt: "Corte infantil en barberia"
  }
];

const serviceList = [
  {
    name: "Cortes clasicos",
    priceFrom: "Bs. 25"
  },
  {
    name: "Cortes modernos",
    priceFrom: "Bs. 30"
  },
  {
    name: "Perfilado de barba",
    priceFrom: "Bs. 15"
  },
  {
    name: "Ceja",
    priceFrom: "Bs. 10"
  },
  {
    name: "Servicio Premium (Corte + Barba)",
    priceFrom: "Bs. 40"
  },
  {
    name: "Servicio VIP (Corte + Barba + Ceja)",
    priceFrom: "Bs. 50"
  }
];

const mapsLink = import.meta.env.PUBLIC_GOOGLE_MAPS_LINK || "https://maps.google.com/?q=OSMI+Barberstudio";
const mapsEmbedUrl =
  import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_URL ||
  "https://www.google.com/maps?q=-17.3890866,-66.2428822&z=18&output=embed";
---

<Layout title="OSMI Barberstudio | Reserva online">
  <header class="sticky top-0 z-20 border-b border-osmi-700/60 bg-osmi-900/80 backdrop-blur reveal reveal-down">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
      <a href="#" class="flex items-center gap-3">
        <img src="/brand/osmi-logo.png" alt="Logo OSMI Barberstudio" class="h-10 w-10 rounded-full object-cover" />
        <span class="font-display text-2xl tracking-[0.2em] text-osmi-100">OSMI</span>
      </a>
      <a
        href="#reservar"
        class="rounded-xl border border-osmi-500 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-osmi-100 transition hover:border-osmi-200 hover:text-white"
      >
        Reservar
      </a>
    </div>
  </header>

  <main class="pb-14">
    <section class="section-shell grid gap-10 pt-20 md:grid-cols-2 md:items-center">
      <div class="space-y-6">
        <p class="pill reveal delay-1">OSMI Barberstudio</p>
        <h1 class="font-display text-5xl leading-tight text-osmi-100 md:text-7xl reveal delay-2">
          Imagen impecable,
          <span class="block text-osmi-200">corte de precision.</span>
        </h1>
        <p class="max-w-xl text-base text-osmi-300 md:text-lg reveal delay-3">
          Vive una experiencia premium con tecnicas modernas y estilo clasico. Reserva en segundos y
          asegura tu proxima cita sin complicaciones.
        </p>
        <div class="flex flex-wrap gap-3 reveal delay-4">
          <a
            href="#reservar"
            class="inline-flex rounded-xl bg-osmi-200 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-osmi-950 transition hover:bg-white"
          >
            Reservar ahora
          </a>
          <a
            href="#ubicacion"
            class="inline-flex rounded-xl border border-osmi-500 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-osmi-100 transition hover:border-osmi-300 hover:text-white"
          >
            Ver ubicacion
          </a>
        </div>
        <div class="flex flex-wrap gap-2 pt-2 reveal delay-5">
          <span class="pill">+1,200 clientes atendidos</span>
          <span class="pill">Atencion personalizada</span>
          <span class="pill">Reserva inmediata</span>
        </div>
      </div>
      <div class="glass-card overflow-hidden p-0 reveal reveal-right delay-3">
        <img
          src="/BarberShop/8a36c1fe02df62cdad2e70dff2f6e43e.jpg"
          alt="Barbero realizando un corte profesional"
          class="h-[26rem] w-full object-cover"
          loading="lazy"
        />
      </div>
    </section>

    <section id="servicios" class="section-shell pt-20">
      <div class="text-center">
        <p class="pill mx-auto w-fit reveal">Mejora tu imagen</p>
        <h2 class="mt-4 font-display text-4xl text-osmi-100 md:text-5xl reveal delay-1">Servicios</h2>
        <p class="mx-auto mt-3 max-w-3xl text-osmi-300 reveal delay-2">
          Elige tu estilo con precios claros y acabados premium para mantener tu imagen siempre impecable.
        </p>
      </div>

      <div class="mt-12 flex items-end justify-center gap-4 md:gap-8 lg:gap-10">
        {
          serviceGallery.map((service, index) => (
            <figure
              class:list={["service-photo reveal", service.featured && "service-photo--featured"]}
              style={`animation-delay: ${index * 120}ms;`}
            >
              <img src={service.image} alt={service.alt} loading="lazy" />
            </figure>
          ))
        }
      </div>

      <div class="glass-card mx-auto mt-12 w-full  py-6 md:p-10 lg:p-12 reveal delay-2">
        <div class="mb-7 flex items-center gap-4">
          <span class="h-px flex-1 bg-osmi-700" aria-hidden="true"></span>
          <h3 class="font-display text-xl uppercase tracking-[0.25em] text-osmi-100 md:text-2xl">Servicios</h3>
          <span class="h-px flex-1 bg-osmi-700" aria-hidden="true"></span>
        </div>

        <ul class="space-y-1">
          {
            serviceList.map((service, index) => (
              <li class="price-list-row reveal" style={`animation-delay: ${140 + index * 90}ms;`}>
                <span class="price-list-name">{service.name}</span>
                <span class="price-list-dots" aria-hidden="true"></span>
                <span class="price-list-price">{service.priceFrom}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mt-9 flex flex-col items-center gap-3 text-center reveal delay-3">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-osmi-300">Reserva tu lugar ahora</p>
        <a
          href="#reservar"
          class="inline-flex rounded-xl bg-osmi-200 px-8 py-3.5 text-sm font-semibold uppercase tracking-wide text-osmi-950 transition hover:bg-white"
        >
          Reservar ya
        </a>
      </div>
    </section>

    <section id="ubicacion" class="section-shell pt-28">
      <div class="grid items-stretch gap-6 lg:grid-cols-[0.45fr_1fr]">
        <div class="glass-card flex h-full flex-col p-6 md:p-8 reveal reveal-left">
          <img
            src="/BarberShop/712ef6b087f64f3d7f7ea8d5735b6795.jpg"
            alt="Interior de la barberia OSMI"
            class="mb-6 h-44 w-full rounded-2xl object-cover"
            loading="lazy"
          />
          <p class="pill w-fit">Ubicacion</p>
          <h2 class="mt-4 font-display text-3xl text-osmi-100 md:text-4xl">Visitanos en OSMI Barberstudio</h2>
          
          <a
            href={mapsLink}
            target="_blank"
            rel="noreferrer"
            class="mt-6 inline-flex rounded-xl border border-osmi-500 px-5 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-osmi-100 transition hover:border-osmi-300 hover:text-white lg:mt-auto"
          >
            Abrir en Google Maps
          </a>
        </div>
        <div class="glass-card min-h-[380px] overflow-hidden p-0 reveal reveal-right delay-2">
          <iframe
            title="Ubicacion OSMI Barberstudio en Google Maps"
            src={mapsEmbedUrl}
            class="h-full min-h-[380px] w-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <BookingForm />
  </main>
</Layout>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(18px) scale(0.99);
    animation: reveal-up 0.7s ease-out forwards;
  }

  .reveal-left {
    transform: translateX(-24px);
    animation-name: reveal-left;
  }

  .reveal-right {
    transform: translateX(24px);
    animation-name: reveal-right;
  }

  .reveal-down {
    transform: translateY(-16px);
    animation-name: reveal-down;
  }

  .delay-1 { animation-delay: 90ms; }
  .delay-2 { animation-delay: 180ms; }
  .delay-3 { animation-delay: 270ms; }
  .delay-4 { animation-delay: 360ms; }
  .delay-5 { animation-delay: 450ms; }

  .service-photo {
    width: 6rem;
    height: 6rem;
    border-radius: 999px;
    overflow: hidden;
    border: 1px solid rgb(153 157 160 / 0.35);
    box-shadow:
      0 14px 26px rgb(0 0 0 / 0.32),
      0 0 0 1px rgb(242 244 245 / 0.06) inset;
    background: rgb(61 65 68 / 0.45);
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }

  .service-photo img {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    object-fit: cover;
    transition: transform 320ms ease, filter 320ms ease;
  }

  .service-photo:hover {
    transform: translateY(-6px) scale(1.02);
    border-color: rgb(217 222 225 / 0.7);
    box-shadow:
      1px 24px 36px rgb(0 0 0 / 0.4),
      0 0 0 1px rgb(242 244 245 / 0.18) inset;
  }

  .service-photo:hover img {
    transform: scale(1.08);
    filter: saturate(1.08) contrast(1.04);
  }

  .service-photo--featured {
    width: 8rem;
    height: 8rem;
  }

  .price-list-row {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    padding: 0.55rem 0;
    color: rgb(242 244 245);
  }

  .price-list-name {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 1.03rem;
  }

  .price-list-dots {
    flex: 1;
    min-width: 1rem;
    border-bottom: 1px dotted rgb(184 188 191 / 0.66);
    transform: translateY(-0.25rem);
  }

  .price-list-price {
    flex-shrink: 0;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: rgb(217 222 225);
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.99);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes reveal-left {
    from {
      opacity: 0;
      transform: translateX(-24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes reveal-right {
    from {
      opacity: 0;
      transform: translateX(24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes reveal-down {
    from {
      opacity: 0;
      transform: translateY(-16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .reveal-left,
    .reveal-right,
    .reveal-down {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (min-width: 768px) {
    .service-photo {
      width: 8.25rem;
      height: 8.25rem;
    }

    .service-photo--featured {
      width: 11rem;
      height: 11rem;
    }

    .price-list-name {
      font-size: 1.2rem;
    }

    .price-list-price {
      font-size: 1rem;
    }
  }

  @media (min-width: 1280px) {
    .service-photo {
      width: 9.25rem;
      height: 9.25rem;
    }

    .service-photo--featured {
      width: 12rem;
      height: 12rem;
    }

    .price-list-name {
      font-size: 1.28rem;
    }
  }
</style>
