---
import BookingForm from "../components/BookingForm.astro";
import Layout from "../layouts/Layout.astro";

const serviceCards = [
  {
    name: "Corte premium",
    detail: "Acabado detallado para un look impecable, con degradado de precision.",
    time: "45 min",
    priceFrom: "Desde Bs. 60",
    image: "/BarberShop/High Fade Haircuts_ Bold Styles for Men.jpeg",
    alt: "Servicio de corte premium en barberia"
  },
  {
    name: "Barba y perfilado",
    detail: "Contornos limpios con navaja, toalla caliente y acabado de alto detalle.",
    time: "30 min",
    priceFrom: "Desde Bs. 45",
    image: "/BarberShop/_ (1).jpeg",
    alt: "Perfilado de barba profesional"
  },
  {
    name: "Corte + barba",
    detail: "Servicio completo para renovar tu estilo y salir listo para cualquier ocasion.",
    time: "60 min",
    priceFrom: "Desde Bs. 95",
    image: "/BarberShop/bf0ce6542fb5135657e9ff8d550ce528.jpg",
    alt: "Paquete de corte y barba"
  }
];

const mapsLink = import.meta.env.PUBLIC_GOOGLE_MAPS_LINK || "https://maps.google.com/?q=OSMI+Barberstudio";
const mapsEmbedUrl =
  import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED_URL ||
  "https://www.google.com/maps?q=-17.3890866,-66.2428822&z=18&output=embed";
---

<Layout title="OSMI Barberstudio | Reserva online">
  <header class="sticky top-0 z-20 border-b border-osmi-700/60 bg-osmi-900/80 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
      <a href="#" class="flex items-center gap-3">
        <img src="/brand/osmi-logo.png" alt="Logo OSMI Barberstudio" class="h-10 w-10 rounded-full object-cover" />
        <span class="font-display text-2xl tracking-[0.2em] text-osmi-100">OSMI</span>
      </a>
      <a
        href="#reservar"
        class="rounded-xl border border-osmi-500 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-osmi-100 transition hover:border-osmi-200 hover:text-white"
      >
        Reservar
      </a>
    </div>
  </header>

  <main class="pb-14">
    <section class="section-shell grid gap-10 pt-20 md:grid-cols-2 md:items-center">
      <div class="space-y-6">
        <p class="pill">OSMI Barberstudio</p>
        <h1 class="font-display text-5xl leading-tight text-osmi-100 md:text-7xl">
          Imagen impecable,
          <span class="block text-osmi-200">corte de precision.</span>
        </h1>
        <p class="max-w-xl text-base text-osmi-300 md:text-lg">
          Vive una experiencia premium con tecnicas modernas y estilo clasico. Reserva en segundos y
          asegura tu proxima cita sin complicaciones.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="#reservar"
            class="inline-flex rounded-xl bg-osmi-200 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-osmi-950 transition hover:bg-white"
          >
            Reservar ahora
          </a>
          <a
            href="#ubicacion"
            class="inline-flex rounded-xl border border-osmi-500 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-osmi-100 transition hover:border-osmi-300 hover:text-white"
          >
            Ver ubicacion
          </a>
        </div>
        <div class="flex flex-wrap gap-2 pt-2">
          <span class="pill">+1,200 clientes atendidos</span>
          <span class="pill">Atencion personalizada</span>
          <span class="pill">Reserva inmediata</span>
        </div>
      </div>
      <div class="glass-card overflow-hidden p-0">
        <img
          src="/BarberShop/8a36c1fe02df62cdad2e70dff2f6e43e.jpg"
          alt="Barbero realizando un corte profesional"
          class="h-[26rem] w-full object-cover"
          loading="lazy"
        />
      </div>
    </section>

    <section class="section-shell pt-20">
      <div class="mb-7 flex flex-col gap-2">
        <p class="pill w-fit">Servicios</p>
        <h2 class="font-display text-3xl text-osmi-100 md:text-5xl">Servicios destacados</h2>
        <p class="max-w-2xl text-osmi-300">
          Diseñados para mantener tu estilo siempre impecable, con tiempos claros y acabado premium.
        </p>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {
          serviceCards.map((service) => (
            <article class="media-card">
              <img src={service.image} alt={service.alt} class="h-52 w-full object-cover" loading="lazy" />
              <div class="space-y-3 p-5">
                <h3 class="font-display text-2xl text-osmi-100">{service.name}</h3>
                <p class="text-sm text-osmi-300">{service.detail}</p>
                <div class="flex items-center justify-between pt-2 text-xs uppercase tracking-[0.2em] text-osmi-400">
                  <span>{service.time}</span>
                  <span>{service.priceFrom}</span>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="ubicacion" class="section-shell pt-28">
      <div class="grid items-stretch gap-6 lg:grid-cols-[0.45fr_1fr]">
        <div class="glass-card flex h-full flex-col p-6 md:p-8">
          <img
            src="/BarberShop/712ef6b087f64f3d7f7ea8d5735b6795.jpg"
            alt="Interior de la barberia OSMI"
            class="mb-6 h-44 w-full rounded-2xl object-cover"
            loading="lazy"
          />
          <p class="pill w-fit">Ubicacion</p>
          <h2 class="mt-4 font-display text-3xl text-osmi-100 md:text-4xl">Visitanos en OSMI Barberstudio</h2>
          
          <a
            href={mapsLink}
            target="_blank"
            rel="noreferrer"
            class="mt-6 inline-flex rounded-xl border border-osmi-500 px-5 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-osmi-100 transition hover:border-osmi-300 hover:text-white lg:mt-auto"
          >
            Abrir en Google Maps
          </a>
        </div>
        <div class="glass-card min-h-[380px] overflow-hidden p-0">
          <iframe
            title="Ubicacion OSMI Barberstudio en Google Maps"
            src={mapsEmbedUrl}
            class="h-full min-h-[380px] w-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <BookingForm />
  </main>
</Layout>
